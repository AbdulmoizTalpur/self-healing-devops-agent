# GitHub API Credentials
# Token must have 'contents:write', 'pull-requests:write', and 'actions:read' permissions
GITHUB_TOKEN=your_github_pat_token

# LLM Backend Provider (gemini | openai | openrouter)
LLM_PROVIDER=gemini

# Gemini API Key (Required if LLM_PROVIDER=gemini)
# Sign up at Google AI Studio
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / OpenRouter Config (Required if LLM_PROVIDER=openai or openrouter)
OPENAI_API_KEY=your_openai_or_openrouter_api_key
OPENAI_MODEL=gpt-4o-mini
# Set this to https://openrouter.ai/api/v1 if using OpenRouter
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Slack Webhook URL for progress updates
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/X00

# Agent Configuration
CONFIDENCE_THRESHOLD=0.65
